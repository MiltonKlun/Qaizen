  "story": {
    "id": "STORY-003",
    "title": "Cart badge shows stale item count after removing an item",
    "source": "manual",
    "path": "story.md",
    "description": "After a user removes an item, the cart badge must decrement immediately without a page reload; a recent refactor cached the count so the header shows a stale value until the next navigation."
  },
  "acceptance_criteria": [
    "Given a cart with N items, when the user removes one item from the cart page, then the header badge updates to N-1 without a page reload.",
    "Given the user removes the last remaining item, when the cart becomes empty, then the header badge is hidden entirely (not shown as \"0\").",
    "Given the user removes an item, when they navigate to another page and back, then the badge still shows the correct count (the fix must not depend on a reload to \"correct itself\")."
  ],
  "ambiguities": [],
  "risks": [
    {
      "risk_id": "RISK-001",
      "description": "The cart badge shows a stale (pre-removal) count after a remove until a reload, misrepresenting cart state at the moment the user decides to check out.",
      "severity": "high",
      "related_acs": [0, 2]
    },
    {
      "risk_id": "RISK-002",
      "description": "When the cart becomes empty the badge shows \"0\" or remains visible instead of disappearing, indicating a phantom item.",
      "severity": "medium",
      "related_acs": [1]
    }
  ],
