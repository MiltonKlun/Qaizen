node_modules/
.env
.env.local
*.local
reports/
# Newman outputs (already covered by reports/ above; listed explicitly per
# Phase 1.5 TG2 — results go to CI artifacts, never versioned).
reports/newman-html/
reports/newman-results.json
traces/
playwright-report/
test-results/
.playwright-mcp/
.DS_Store
.claude/

# Phase 3 run history (scripts/new-run.js). Archived runs under runs/ ARE
# versioned for their durable artifacts (context.json, test-cases/, specs/,
# tests/, analysis/, release/, planner-input/, api-tests/, run-manifest.json),
# but the heavy regenerable outputs are not — same rule as the repo root.
runs/**/reports/
runs/**/traces/
runs/**/screenshots/

# Demo workspaces (scripts/demo-pipeline.js, IMPROVEMENT-PLAN Phase 3). The
# demo creates a throwaway, DEMO-sentinel-marked run under runs/DEMO-1/; it is
# replayed from examples/demo-run/ on every `npm run demo:pipeline` and is
# never a versioned artifact.
runs/DEMO-1/

# Healer isolated workspace (Phase 3 TG2). The Healer validates candidate
# patches in a throwaway copy; the reviewable output is release/healer-patches/
# + analysis/healer-validation/, which ARE versioned. The workspace is not.
.healer-workspace/

# Phase 3 TG6 metrics outputs are regenerable from runs/ — keep the dir
# (metrics/.gitkeep), not the generated files.
metrics/pipeline-metrics.json
metrics/pipeline-metrics.md

# Phase 3 TG10 /evolve proposal is regenerable from git + metrics + session
# summaries — keep the dir (evolve/.gitkeep), not the generated proposal.
# session-summaries/ ARE versioned (durable human input /evolve reads).
evolve/evolve-proposal.json
evolve/evolve-proposal.md

# Throwaway mini-repos created by the runner black-box tests (test/run-pipeline.test.js)
.tmp-runner-*/
