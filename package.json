{
  "name": "qaizen",
  "version": "0.1.0",
  "description": "Qaizen: AI-assisted, human-gated QA pipeline — user story -> validated test cases -> Playwright E2E + Postman API -> classified failures -> release report.",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:regression": "playwright test --grep @regression",
    "test:api": "node scripts/run-newman.js",
    "test:unit": "node --test test/healer-guardrails.test.js test/pipeline-state.test.js test/track-floor.test.js test/gate4-scan.test.js",
    "test:smoke": "node --test test/scripts-smoke.test.js test/run-pipeline.test.js",
    "test:pipeline": "node --test test/healer-guardrails.test.js test/pipeline-state.test.js test/track-floor.test.js test/gate4-scan.test.js test/scripts-smoke.test.js test/run-pipeline.test.js",
    "pipeline": "node scripts/run-pipeline.js",
    "validate:context": "node scripts/validate-json.js schemas/context.schema.json context.json",
    "validate:examples": "node scripts/validate-examples.js",
    "validate:all": "node scripts/validate-all.js",
    "ci:summary": "node scripts/ci-summary.js",
    "evaluate": "node scripts/evaluate-agents.js",
    "fetch-story": "node scripts/fetch-jira-story.js",
    "export:jira": "node scripts/export-to-jira.js",
    "sync:jira-testcases": "node scripts/create-jira-testcases.js",
    "migrate:external-ids": "node scripts/migrate-testcases-external-ids.js",
    "migrate:release-report-tg12": "node scripts/migrate-release-report-tg12.js",
    "migrate:gate-decisions": "node scripts/migrate-context-gate-decisions.js",
    "new-run": "node scripts/new-run.js",
    "list-runs": "node scripts/list-runs.js",
    "classify": "node scripts/run-failure-classifier.js",
    "heal": "node scripts/run-healer.js",
    "demo:healer": "node scripts/demo-healer-green-red.js",
    "demo:pipeline": "node scripts/demo-pipeline.js",
    "metrics": "node scripts/pipeline-metrics.js",
    "scan:gate4": "node scripts/gate4-scan.js",
    "benchmark:capture": "node scripts/benchmark-capture.js",
    "benchmark:survival": "node scripts/selector-survival.js",
    "evolve": "node scripts/evolve.js",
    "session-summary": "node scripts/session-summary.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-playwright": "^2.10.4",
    "newman": "^6.2.2",
    "newman-reporter-htmlextra": "^1.23.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
