# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# ----------------------------------------------------------------------------
# Phase 1 — Atlassian (Jira + Confluence) via mcp-atlassian, read-only mode
# ----------------------------------------------------------------------------

# Jira Cloud base URL, e.g. https://your-domain.atlassian.net
JIRA_URL=https://your-domain.atlassian.net

# Atlassian account email used to create the API token
JIRA_USERNAME=

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Default Jira project key, e.g. "PROJ" or "QA"
JIRA_PROJECT_KEY=

# Confluence (may share the same Atlassian site as Jira)
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=

# ----------------------------------------------------------------------------
# Phase 1 — Application under test
# ----------------------------------------------------------------------------

# Base URL of the application that Playwright will exercise
BASE_URL=

# ----------------------------------------------------------------------------
# Phase 1 — MCP Atlassian tool allowlist (READ-ONLY in Phase 1)
# ----------------------------------------------------------------------------
# Phase 1 only permits read tools. Writes (jira_create_issue,
# jira_update_issue, jira_add_comment, etc.) are NOT in this list and will
# fail at the MCP layer if the agent attempts them. Phase 2 expands this.

ENABLED_TOOLS=jira_get_issue,jira_search,jira_get_issue_link_types,confluence_get_page,confluence_search

# ----------------------------------------------------------------------------
# Phase 1.5 — API branch (Postman MCP + Newman)
# ----------------------------------------------------------------------------

# Postman API key, from https://go.postman.co/settings/me/api-keys
# Used by the official @postman/postman-mcp-server (local STDIO mode) so the
# API Agent can read/write collections. Newman execution itself does not need
# this key (it runs collection files directly from disk).
POSTMAN_API_KEY=

# Optional: the Postman workspace the API Agent should read/write collections
# in. Leave blank to use the account default.
POSTMAN_WORKSPACE_ID=

# Base URL for the API under test. Per docs/ambiguities.md A3 (resolved),
# the Phase 1.5 API branch targets reqres.in because Saucedemo has no real
# backend API. Collections reference this via an environment variable, never
# hardcoded.
API_BASE_URL=https://reqres.in/api

# reqres.in now requires a free x-api-key header on all /api/* endpoints.
# Get one at https://app.reqres.in/api-keys. The Newman environment reads it
# as {{api_key}} and sends it as the x-api-key header; never hardcode it in
# the collection. (Discovered during Phase 1.5 TG9 — see docs/ambiguities.md A5.)
REQRES_API_KEY=

# ----------------------------------------------------------------------------
# Phase 2 — TestLink (test management) via dogkeeper886/testlink-mcp
# ----------------------------------------------------------------------------
# TestLink is self-hosted; the pipeline does not install it. See
# docs/testlink-integration.md (TG3) and docs/secrets-management.md.

# Base URL of your TestLink instance, e.g. https://testlink.example.com
TESTLINK_URL=

# TestLink API key: in TestLink, User Settings -> Generate a new API key.
TESTLINK_API_KEY=

# The TestLink project the pipeline syncs test cases into.
TESTLINK_PROJECT_KEY=

# The TestLink test plan that execution results are reported against.
TESTLINK_TEST_PLAN_ID=

# ----------------------------------------------------------------------------
# Phase 2 — Atlassian writes-enabled allowlist
# ----------------------------------------------------------------------------
# Phase 1 used ENABLED_TOOLS with read-only tools. Phase 2 adds an expanded
# allowlist that includes the write tools (jira_create_issue, jira_update_issue,
# jira_add_comment). The agent still NEVER creates Jira issues as a side effect
# — bug creation only happens via `node scripts/create-jira-bugs.js --apply`
# with an explicit human-supplied flag. Point the atlassian MCP at this value
# (instead of the read-only ENABLED_TOOLS) only when you intend writes.
# Recommendation: keep a separate .env.prod for the write-enabled value and a
# .env.dev for read-only. See docs/mcp-setup.md.
ATLASSIAN_ENABLED_TOOLS_WRITE=jira_get_issue,jira_search,jira_create_issue,jira_update_issue,jira_add_comment,confluence_get_page,confluence_search

# Issue type used when promoting bug drafts to Jira (configurable; default Bug).
JIRA_BUG_ISSUETYPE=Bug

# Phase 2.6 — pluggable test-case destination (TestManagementAdapter port).
# Which tool the test-case sync writes to: testlink | jira | both | none.
# The Jira adapter (scripts/create-jira-testcases.js) only runs when this is
# jira or both. See agents/test-management-adapter.md.
TEST_MANAGEMENT_TOOL=testlink
# Issue type for test cases created in Jira (TG2.6-3). MUST be a type your
# Jira project actually has — many sites have no "Test" type; "Task" is a safe
# default. (Verified: the SK demo project only has Task, not Test.)
JIRA_TESTCASE_ISSUETYPE=Task

# Phase 3 TG15 — code-change awareness (GitHub MCP, READ-ONLY).
# A fine-grained PAT scoped to READ pull requests + contents on the repo(s)
# whose PRs your Jira stories link to. The Analyst (Mode B) uses it to fetch a
# linked PR's diff as SECONDARY context only — never to define expected
# behavior, and never to write to GitHub. Optional: with no linked PR, the
# pipeline runs identically and this is unused.
GITHUB_PERSONAL_ACCESS_TOKEN=
# Restrict the MCP's surface to read-only toolsets (no write tools loaded).
GITHUB_TOOLSETS=repos,pull_requests
